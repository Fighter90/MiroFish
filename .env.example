# ===== Flask =====
# Обязательно в проде: выключить debug и задать секретный ключ подписи сессий
FLASK_DEBUG=false
# Сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_hex_chars

# ===== Основной LLM (OpenAI-совместимый) =====
# Рекомендуется Qwen 3.5 через OpenRouter: https://openrouter.ai/
# Альтернативы: Alibaba DashScope (Bailian), OpenAI, любой совместимый провайдер
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=qwen/qwen3.5-122b-a10b

# ===== Ускоренный LLM (вспомогательные задачи: нормализация имён, лёгкая генерация) =====
# Обычно меньшая модель того же провайдера
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=https://openrouter.ai/api/v1
LLM_BOOST_MODEL_NAME=qwen/qwen3.5-27b

# ===== Zep Cloud (граф знаний, память агентов) =====
# Бесплатного тарифа достаточно для базового использования: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here
